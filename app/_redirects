# Cloudflare Pages may 302 /page.html → /page (“pretty URLs”). That breaks auth ?return= which
# expects real paths like /locker.html. These 301s send extensionless URLs back to the .html file
# so the final address bar (and pathname) match our static file names. Query strings are preserved
# by the client redirect chain per Pages behavior.
#
# Login uses the SAME extensionless pattern as /admin (below). Query strings are preserved on 301s.
# pilot-auth normalizes /login → /login.html in return paths (lantern-pilot-auth.js).
#
# Locker, store, games, admin, login — SAME pattern (extensionless canonical, no /page ↔ /page.html loop):
# - /page/ → /page (301) — one trailing-slash shape
# - /page.html → /page (301) — bookmarked .html URLs collapse to extensionless
# - /page → /page.html (200) — proxy: serve file without Location redirect to .html
# Order per route: /path/ first, then /path.html, then /path.

# Root: serve index.html (client redirects to /login.html). Do NOT rewrite / → login.html — that
# conflicted with index.html + Pages routing and could contribute to redirect chains.

/locker/ /locker 301
/locker.html /locker 301
/locker /locker.html 200

/store/ /store 301
/store.html /store 301
/store /store.html 200

/games/ /games 301
/games.html /games 301
/games /games.html 200

/admin/ /admin 301
/admin.html /admin 301
/admin /admin.html 200

/login/ /login 301
/login.html /login 301
/login /login.html 200

/teacher /teacher.html 301
/explore /explore.html 301
/change-password /change-password.html 301
